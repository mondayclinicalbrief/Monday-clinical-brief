---
permalink: /samples/index.html
eleventyExcludeFromCollections: true
title: "Sample Digests — All 31 Specialties"
description: "Browse a real recent Monday Clinical Brief digest for every specialty we cover — from Acute Medicine to Urology. See the format, depth, and journal coverage before you subscribe."
specialties:
  - { slug: acute-medicine, name: "Acute Medicine" }
  - { slug: anaesthetics, name: "Anaesthetics" }
  - { slug: cardiology, name: "Cardiology" }
  - { slug: cardiothoracic-surgery, name: "Cardiothoracic Surgery" }
  - { slug: dermatology, name: "Dermatology" }
  - { slug: emergency-medicine, name: "Emergency Medicine" }
  - { slug: endocrinology, name: "Endocrinology" }
  - { slug: gastroenterology, name: "Gastroenterology" }
  - { slug: general-practice, name: "General Practice" }
  - { slug: general-surgery, name: "General Surgery" }
  - { slug: geriatric-medicine, name: "Geriatric Medicine" }
  - { slug: haematology, name: "Haematology" }
  - { slug: infectious-disease, name: "Infectious Disease" }
  - { slug: intensive-care, name: "Intensive Care" }
  - { slug: nephrology, name: "Nephrology" }
  - { slug: neurology, name: "Neurology" }
  - { slug: neurosurgery, name: "Neurosurgery" }
  - { slug: obstetrics-gynaecology, name: "Obstetrics & Gynaecology" }
  - { slug: oncology, name: "Oncology" }
  - { slug: ophthalmology, name: "Ophthalmology" }
  - { slug: orthopaedic-surgery, name: "Orthopaedic Surgery" }
  - { slug: paediatrics, name: "Paediatrics" }
  - { slug: palliative-care, name: "Palliative Care" }
  - { slug: pathology, name: "Pathology" }
  - { slug: plastic-surgery, name: "Plastic Surgery" }
  - { slug: psychiatry, name: "Psychiatry" }
  - { slug: public-health, name: "Public Health" }
  - { slug: radiology, name: "Radiology" }
  - { slug: respiratory, name: "Respiratory" }
  - { slug: rheumatology, name: "Rheumatology" }
  - { slug: urology, name: "Urology" }
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — The Monday Clinical Brief</title>
<meta name="description" content="{{ description }}">
<link rel="canonical" href="https://mondayclinicalbrief.co.uk/samples/">

<!-- Open Graph -->
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ description }}">
<meta property="og:type" content="website">
<meta property="og:url" content="https://mondayclinicalbrief.co.uk/samples/">
<meta property="og:site_name" content="The Monday Clinical Brief">
<meta name="twitter:card" content="summary_large_image">

<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Figtree:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root {
    --charcoal: #1c1c1c;
    --cream: #f7f5f0;
    --warm-white: #fdfcf9;
    --sage: #5a7a6a;
    --sage-light: #e8efeb;
    --sage-deep: #3d5a4c;
    --gold: #c4994c;
    --gold-light: #f5edd8;
    --text: #3a3a38;
    --text-muted: #7a7a76;
    --border: #e2dfd8;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Figtree', sans-serif; color: var(--text); background: var(--warm-white); line-height: 1.7; -webkit-font-smoothing: antialiased; }

  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; background: rgba(247,245,240,0.9); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(226,223,216,0.5); }
  .nav-brand { font-family: 'Instrument Serif', serif; font-size: 1.8rem; font-weight: 700; color: var(--charcoal); text-decoration: none; letter-spacing: -0.02em; }
  .nav-links { display: flex; gap: 1.5rem; align-items: center; }
  .nav-links a { font-size: 0.85rem; color: var(--text-muted); text-decoration: none; font-weight: 500; transition: color 0.2s; }
  .nav-links a:hover { color: var(--sage-deep); }
  .nav-cta { background: var(--sage-deep); color: white !important; padding: 0.5rem 1.25rem; border-radius: 40px; font-size: 0.85rem; }
  .nav-cta:hover { background: var(--charcoal); }

  .breadcrumb { padding: 6rem 2rem 0; max-width: 1000px; margin: 0 auto; }
  .breadcrumb ol { list-style: none; display: flex; flex-wrap: wrap; gap: 0.25rem; font-size: 0.8rem; color: var(--text-muted); }
  .breadcrumb ol li::after { content: '/'; margin-left: 0.4rem; opacity: 0.4; }
  .breadcrumb ol li:last-child::after { content: ''; }
  .breadcrumb a { color: var(--sage); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .samples-hero { padding: 2.5rem 2rem 1.5rem; text-align: center; max-width: 680px; margin: 0 auto; }
  .samples-hero h1 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4.5vw, 2.8rem); font-weight: 400; color: var(--charcoal); line-height: 1.2; margin-bottom: 0.75rem; }
  .samples-hero p { color: var(--text-muted); font-size: 1.05rem; }

  .samples-grid { max-width: 1000px; margin: 0 auto; padding: 1.5rem 2rem 3rem; display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.9rem; }
  .sample-card { display: flex; align-items: center; justify-content: space-between; background: white; border: 1px solid var(--border); border-radius: 8px; padding: 1rem 1.25rem; text-decoration: none; color: var(--charcoal); font-weight: 600; font-size: 0.95rem; transition: all 0.2s; }
  .sample-card:hover { border-color: var(--sage); background: var(--sage-light); color: var(--sage-deep); box-shadow: 0 4px 16px rgba(0,0,0,0.05); }
  .sample-card .arrow { color: var(--sage); font-weight: 400; }

  .samples-cta { max-width: 680px; margin: 0 auto 3rem; padding: 2rem; text-align: center; background: var(--cream); border-radius: 8px; }
  .samples-cta h2 { font-family: 'Instrument Serif', serif; font-size: 1.5rem; font-weight: 400; color: var(--charcoal); margin-bottom: 0.5rem; }
  .samples-cta p { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 1.25rem; }
  .btn-primary { display: inline-block; background: var(--sage-deep); color: white; text-decoration: none; padding: 0.75rem 2rem; border-radius: 60px; font-weight: 600; font-size: 0.95rem; transition: all 0.3s ease; }
  .btn-primary:hover { background: var(--charcoal); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }

  footer { padding: 3rem 2rem; text-align: center; border-top: 1px solid var(--border); }
  footer p { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 0.5rem; }
  footer a { color: var(--sage); text-decoration: none; }

  @media (max-width: 640px) {
    nav { padding: 0.75rem 1rem; position: fixed; top: auto; bottom: 0; border-bottom: none; border-top: 1px solid rgba(226,223,216,0.5); }
    .nav-links a:not(.nav-cta) { display: none; }
    body { padding-bottom: 60px; }
    .breadcrumb { padding-top: 2rem; }
  }
</style>

<!-- Schema.org: ItemList of all specialty samples -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "{{ title }}",
  "description": "{{ description }}",
  "url": "https://mondayclinicalbrief.co.uk/samples/",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": [
      {%- for s in specialties %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "name": "{{ s.name }} Sample Digest",
        "url": "https://mondayclinicalbrief.co.uk/samples/{{ s.slug }}/"
      }{% if not loop.last %},{% endif %}
      {%- endfor %}
    ]
  }
}
</script>
</head>
<body>

<nav>
  <a href="/" class="nav-brand">The Monday Clinical Brief</a>
  <div class="nav-links">
    <a href="/samples/">Samples</a>
    <a href="/blog/">Blog</a>
    <a href="/#how">How it works</a>
    <a href="/#subscribe" class="nav-cta">Start free trial</a>
  </div>
</nav>

<div class="breadcrumb" aria-label="Breadcrumb">
  <ol>
    <li><a href="/">Home</a></li>
    <li>Sample digests</li>
  </ol>
</div>

<div class="samples-hero">
  <h1>Sample digests — all 31 specialties</h1>
  <p>Every specialty we cover, with a real recent digest exactly as it reaches subscribers. See the format, the depth, and the journals we track before you sign up.</p>
</div>

<div class="samples-grid">
  {%- for s in specialties %}
  <a class="sample-card" href="/samples/{{ s.slug }}/">{{ s.name }} <span class="arrow">→</span></a>
  {%- endfor %}
</div>

<div class="samples-cta">
  <h2>One specialty included. Add more for £5 each.</h2>
  <p>Your subscription covers the top 5 journals in your specialty, every Monday. Add any of the other 30 specialties for £5/year each.</p>
  <a href="/#subscribe" class="btn-primary">Start your free trial →</a>
</div>

<footer>
  <p>&copy; 2025 The Monday Clinical Brief. All rights reserved.</p>
  <p><a href="/samples/">Samples</a> · <a href="/blog/">Blog</a> · <a href="/privacy.html">Privacy</a> · <a href="/terms.html">Terms</a></p>
</footer>

</body>
</html>
