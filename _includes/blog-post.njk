<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ seoTitle or title }} — The Monday Clinical Brief</title>
<meta name="description" content="{{ metaDescription or description }}">
<link rel="canonical" href="https://mondayclinicalbrief.co.uk{{ page.url }}">
{% if noindex %}<meta name="robots" content="noindex">{% endif %}

<!-- Open Graph -->
<meta property="og:title" content="{{ seoTitle or title }}">
<meta property="og:description" content="{{ metaDescription or description }}">
<meta property="og:type" content="article">
<meta property="og:url" content="https://mondayclinicalbrief.co.uk{{ page.url }}">
{% if featuredImage %}<meta property="og:image" content="https://mondayclinicalbrief.co.uk{{ featuredImage }}">{% endif %}
<meta property="og:site_name" content="The Monday Clinical Brief">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seoTitle or title }}">
<meta name="twitter:description" content="{{ metaDescription or description }}">

<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Figtree:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root {
    --charcoal: #1c1c1c;
    --cream: #f7f5f0;
    --warm-white: #fdfcf9;
    --sage: #5a7a6a;
    --sage-light: #e8efeb;
    --sage-deep: #3d5a4c;
    --gold: #c4994c;
    --gold-light: #f5edd8;
    --text: #3a3a38;
    --text-muted: #7a7a76;
    --border: #e2dfd8;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Figtree', sans-serif; color: var(--text); background: var(--warm-white); line-height: 1.7; -webkit-font-smoothing: antialiased; }

  /* ── NAV ── */
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; background: rgba(247,245,240,0.9); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(226,223,216,0.5); }
  .nav-brand { font-family: 'Instrument Serif', serif; font-size: 1.8rem; font-weight: 700; color: var(--charcoal); text-decoration: none; letter-spacing: -0.02em; }
  .nav-links { display: flex; gap: 1.5rem; align-items: center; }
  .nav-links a { font-size: 0.85rem; color: var(--text-muted); text-decoration: none; font-weight: 500; transition: color 0.2s; }
  .nav-links a:hover { color: var(--sage-deep); }
  .nav-cta { background: var(--sage-deep); color: white !important; padding: 0.5rem 1.25rem; border-radius: 40px; font-size: 0.85rem; }
  .nav-cta:hover { background: var(--charcoal); }

  /* ── BREADCRUMB ── */
  .breadcrumb { padding: 6rem 2rem 0; max-width: 760px; margin: 0 auto; }
  .breadcrumb ol { list-style: none; display: flex; flex-wrap: wrap; gap: 0.25rem; font-size: 0.8rem; color: var(--text-muted); }
  .breadcrumb ol li::after { content: '/'; margin-left: 0.4rem; opacity: 0.4; }
  .breadcrumb ol li:last-child::after { content: ''; }
  .breadcrumb a { color: var(--sage); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  /* ── ARTICLE ── */
  .article-header { max-width: 760px; margin: 0 auto; padding: 2rem 2rem 0; }
  .article-cluster { display: inline-block; background: var(--sage-light); color: var(--sage-deep); padding: 0.2rem 0.7rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; margin-bottom: 1rem; text-decoration: none; }
  .article-cluster:hover { background: var(--sage); color: white; }
  .article-header h1 { font-family: 'Instrument Serif', serif; font-size: clamp(2rem, 4.5vw, 2.8rem); font-weight: 400; color: var(--charcoal); line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 1rem; }
  .article-meta { font-size: 0.85rem; color: var(--text-muted); display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .article-meta time { font-weight: 500; }

  /* ── CONTENT ── */
  .article-content { max-width: 760px; margin: 0 auto; padding: 2.5rem 2rem 4rem; }
  .article-content h2 { font-family: 'Instrument Serif', serif; font-size: 1.6rem; font-weight: 400; color: var(--charcoal); line-height: 1.3; margin: 2.5rem 0 1rem; }
  .article-content h3 { font-size: 1.15rem; font-weight: 600; color: var(--charcoal); margin: 2rem 0 0.75rem; }
  .article-content p { margin-bottom: 1.25rem; font-size: 1.02rem; }
  .article-content ul, .article-content ol { margin-bottom: 1.25rem; padding-left: 1.5rem; }
  .article-content li { margin-bottom: 0.4rem; font-size: 1.02rem; }
  .article-content a { color: var(--sage-deep); text-decoration: underline; text-underline-offset: 2px; }
  .article-content a:hover { color: var(--charcoal); }
  .article-content blockquote { border-left: 3px solid var(--sage); padding: 1rem 1.5rem; margin: 1.5rem 0; background: var(--sage-light); border-radius: 0 6px 6px 0; font-style: italic; color: var(--text-muted); }
  .article-content img { max-width: 100%; height: auto; border-radius: 8px; margin: 1.5rem 0; }
  .article-content table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.92rem; }
  .article-content th { background: var(--sage-light); color: var(--sage-deep); font-weight: 600; text-align: left; padding: 0.75rem 1rem; border-bottom: 2px solid var(--sage); }
  .article-content td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--border); }
  .article-content tr:hover td { background: var(--cream); }
  .article-content code { font-size: 0.9em; background: var(--cream); padding: 0.15em 0.4em; border-radius: 3px; }
  .article-content pre { background: var(--charcoal); color: var(--cream); padding: 1.25rem; border-radius: 8px; overflow-x: auto; margin: 1.5rem 0; }
  .article-content pre code { background: none; padding: 0; color: inherit; }

  /* ── CTA BOX ── */
  .cta-box { background: var(--sage-light); border: 1px solid var(--sage); border-radius: 8px; padding: 1.5rem 2rem; margin: 2rem 0; text-align: center; }
  .cta-box h3 { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-weight: 400; color: var(--sage-deep); margin-bottom: 0.5rem; }
  .cta-box p { color: var(--text-muted); margin-bottom: 1rem; font-size: 0.95rem; }
  .cta-box .btn-primary { display: inline-block; background: var(--sage-deep); color: white; text-decoration: none; padding: 0.75rem 2rem; border-radius: 60px; font-family: 'Figtree', sans-serif; font-size: 0.95rem; font-weight: 600; transition: all 0.3s ease; }
  .cta-box .btn-primary:hover { background: var(--charcoal); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }

  /* ── FAQ SECTION ── */
  .faq-section { margin: 3rem 0 2rem; }
  .faq-section h2 { font-family: 'Instrument Serif', serif; font-size: 1.6rem; color: var(--charcoal); margin-bottom: 1.5rem; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 1.25rem 0; }
  .faq-item summary { font-weight: 600; font-size: 1rem; color: var(--charcoal); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: 1.3rem; color: var(--sage); transition: transform 0.2s; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p { margin-top: 0.75rem; color: var(--text-muted); font-size: 0.95rem; }

  /* ── RELATED POSTS ── */
  .related-posts { background: var(--cream); border-radius: 8px; padding: 2rem; margin: 3rem 0; }
  .related-posts h3 { font-family: 'Instrument Serif', serif; font-size: 1.3rem; color: var(--charcoal); margin-bottom: 1rem; }
  .related-posts ul { list-style: none; padding: 0; }
  .related-posts li { padding: 0.5rem 0; border-bottom: 1px solid var(--border); }
  .related-posts li:last-child { border-bottom: none; }
  .related-posts a { color: var(--sage-deep); text-decoration: none; font-weight: 500; }
  .related-posts a:hover { text-decoration: underline; }

  /* ── AUTHOR BOX ── */
  .author-box { display: flex; gap: 1.5rem; align-items: center; background: var(--cream); border-radius: 8px; padding: 1.5rem; margin: 3rem 0; }
  .author-avatar { width: 64px; height: 64px; background: var(--sage-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Instrument Serif', serif; font-size: 1.5rem; color: var(--sage); flex-shrink: 0; }
  .author-info h4 { font-size: 0.95rem; color: var(--charcoal); margin-bottom: 0.25rem; }
  .author-info p { font-size: 0.85rem; color: var(--text-muted); margin: 0; }

  /* ── FOOTER ── */
  footer { padding: 3rem 2rem; text-align: center; border-top: 1px solid var(--border); }
  footer p { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 0.5rem; }
  footer a { color: var(--sage); text-decoration: none; }

  @media (max-width: 640px) {
    nav { padding: 0.75rem 1rem; position: fixed; top: auto; bottom: 0; border-bottom: none; border-top: 1px solid rgba(226,223,216,0.5); z-index: 100; }
    .nav-links a:not(.nav-cta) { display: none; }
    body { padding-bottom: 60px; }
    .breadcrumb { padding-top: 2rem; }
    .article-header { padding-top: 1rem; }
    .article-header h1 { font-size: 1.8rem; }
    .article-content { padding: 1.5rem 1.5rem 3rem; }
    .author-box { flex-direction: column; text-align: center; }
  }
</style>

<!-- Schema.org Structured Data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "{{ schemaType or 'Article' }}",
  "headline": "{{ seoTitle or title }}",
  "description": "{{ metaDescription or description }}",
  "url": "https://mondayclinicalbrief.co.uk{{ page.url }}",
  "datePublished": "{{ date | isoDate }}",
  {% if updated %}"dateModified": "{{ updated | isoDate }}",{% endif %}
  "author": {
    "@type": "Organization",
    "name": "The Monday Clinical Brief",
    "url": "https://mondayclinicalbrief.co.uk"
  },
  "publisher": {
    "@type": "Organization",
    "name": "The Monday Clinical Brief",
    "url": "https://mondayclinicalbrief.co.uk"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://mondayclinicalbrief.co.uk{{ page.url }}"
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://mondayclinicalbrief.co.uk/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": "https://mondayclinicalbrief.co.uk/blog/"
    }{% if cluster %},
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{ cluster }}",
      "item": "https://mondayclinicalbrief.co.uk/blog/{{ cluster | slugify }}/"
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": "{{ title }}"
    }{% else %},
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{ title }}"
    }{% endif %}
  ]
}
</script>

{% if faqs %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in faqs %}
    {
      "@type": "Question",
      "name": "{{ faq.question }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ faq.answer }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

</head>
<body>

<!-- ═══ NAV ═══ -->
<nav>
  <a href="/" class="nav-brand">The Monday Clinical Brief</a>
  <div class="nav-links">
    <a href="/blog/">Blog</a>
    <a href="/#how">How it works</a>
    <a href="/#subscribe" class="nav-cta">Start free trial</a>
  </div>
</nav>

<!-- ═══ BREADCRUMB ═══ -->
<div class="breadcrumb" aria-label="Breadcrumb">
  <ol>
    <li><a href="/">Home</a></li>
    <li><a href="/blog/">Blog</a></li>
    {% if cluster %}<li><a href="/blog/{{ cluster | slugify }}/">{{ cluster }}</a></li>{% endif %}
    <li>{{ title }}</li>
  </ol>
</div>

<!-- ═══ ARTICLE HEADER ═══ -->
<header class="article-header">
  {% if cluster %}
  <a href="/blog/{{ cluster | slugify }}/" class="article-cluster">{{ cluster }}</a>
  {% endif %}
  <h1>{{ title }}</h1>
  <div class="article-meta">
    <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
    <span>{{ content | readingTime }}</span>
    {% if author %}<span>By {{ author }}</span>{% endif %}
  </div>
</header>

<!-- ═══ ARTICLE CONTENT ═══ -->
<article class="article-content">
  {{ content | safe }}

  {% if faqs %}
  <div class="faq-section">
    <h2>Frequently Asked Questions</h2>
    {% for faq in faqs %}
    <details class="faq-item">
      <summary>{{ faq.question }}</summary>
      <p>{{ faq.answer }}</p>
    </details>
    {% endfor %}
  </div>
  {% endif %}

  <!-- CTA Box -->
  <div class="cta-box">
    <h3>Stay on top of the evidence</h3>
    <p>Weekly journal digests for 31 medical specialties. Structured summaries, every Monday.</p>
    <a href="/#subscribe" class="btn-primary">Start your free trial →</a>
  </div>
</article>

<!-- ═══ AUTHOR ═══ -->
{% if author %}
<div style="max-width: 760px; margin: 0 auto; padding: 0 2rem;">
  <div class="author-box">
    <div class="author-avatar">MCB</div>
    <div class="author-info">
      <h4>{{ author }}</h4>
      <p>{{ authorBio or "The Monday Clinical Brief — AI-powered weekly journal digests for UK clinicians." }}</p>
    </div>
  </div>
</div>
{% endif %}

<!-- ═══ FOOTER ═══ -->
<footer>
  <p>&copy; 2025 The Monday Clinical Brief. All rights reserved.</p>
  <p><a href="/privacy.html">Privacy</a> · <a href="/terms.html">Terms</a> · <a href="/blog/">Blog</a></p>
</footer>

</body>
</html>
