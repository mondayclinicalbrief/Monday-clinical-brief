---
layout: blog-index.njk
title: "Journal Summary Subscription"
description: "Comparing journal summary services, understanding what to look for, and making the right choice for your practice."
permalink: /blog/journal-summary-subscription/
---

{% for post in collections.cluster3 %}
<div class="post-card">
  <span class="post-card-cluster">Journal Summary Subscription</span>
  {% if post.data.pillar %}<span class="pillar-badge">Pillar</span>{% endif %}
  <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
  <p>{{ post.data.description }}</p>
  <div class="post-card-meta">
    <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
    <span>{{ post.data.description | readingTime }}</span>
  </div>
</div>
{% endfor %}
