---
layout: blog-index.njk
title: "CPD Reading Tool"
description: "Practical tools, templates, and strategies for CPD reading — from revalidation prep to reflective practice."
permalink: /blog/cpd-reading-tool/
---

{% for post in collections.cluster2 %}
<div class="post-card">
  <span class="post-card-cluster">CPD Reading Tool</span>
  {% if post.data.pillar %}<span class="pillar-badge">Pillar</span>{% endif %}
  <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
  <p>{{ post.data.description }}</p>
  <div class="post-card-meta">
    <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
    <span>{{ post.data.description | readingTime }}</span>
  </div>
</div>
{% endfor %}
