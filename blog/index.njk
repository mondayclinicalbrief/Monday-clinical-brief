---
layout: blog-index.njk
title: "Clinical Reading & CPD Blog"
description: "Evidence-based guides for UK clinicians — medical journal digests, CPD reading strategies, and staying current with the literature."
permalink: /blog/
---

{% for post in collections.posts %}
<div class="post-card">
  {% if post.data.cluster %}<span class="post-card-cluster">{{ post.data.cluster }}</span>{% endif %}
  {% if post.data.pillar %}<span class="pillar-badge">Pillar</span>{% endif %}
  <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
  <p>{{ post.data.description }}</p>
  <div class="post-card-meta">
    <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
    <span>{{ post.data.description | readingTime }}</span>
  </div>
</div>
{% endfor %}
